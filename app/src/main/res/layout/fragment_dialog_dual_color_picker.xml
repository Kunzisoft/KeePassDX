<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:id="@+id/edit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:importantForAutofill="noExcludeDescendants"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <View
                android:id="@+id/color_preview_background"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@color/green" />

            <View
                android:id="@+id/color_preview_foreground"
                android:layout_width="100dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:background="@color/orange" />
        </FrameLayout>


        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.tabs.TabItem
                android:id="@+id/background_tab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:icon="@drawable/ic_color_background_white_24dp"
                android:text="Background" />

            <com.google.android.material.tabs.TabItem
                android:id="@+id/foreground_tab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:icon="@drawable/ic_color_foreground_white_24dp"
                android:text="Foreground" />
        </com.google.android.material.tabs.TabLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_element_background"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:background="@drawable/background_switch"
            android:backgroundTint="?attr/colorSurfaceVariant"
            android:paddingVertical="18dp"
            android:text="@string/enable" />

        <com.kunzisoft.keepass.colorpicker.ColorPicker
            android:id="@+id/color_picker_background"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_element_foreground"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:background="@drawable/background_switch"
            android:backgroundTint="?attr/colorSurfaceVariant"
            android:paddingVertical="18dp"
            android:text="@string/enable"
            android:visibility="gone" />

        <com.kunzisoft.keepass.colorpicker.ColorPicker
            android:id="@+id/color_picker_foreground"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
