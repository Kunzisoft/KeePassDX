<resources>

    <style name="GroupActivityTheme" parent="Theme.Keepass">
        <item name="android:statusBarColor">?colorSurfaceVariant</item>
    </style>

    <style name="SettingsActivityTheme" parent="Theme.Keepass">
        <item name="android:statusBarColor">?colorSurfaceVariant</item>
    </style>

    <style name="FileDatabaseSelectActivityTheme" parent="Theme.Keepass">
        <item name="android:navigationBarColor">?colorSurfaceVariant2</item>
    </style>

    <style name="MainCredentialActivityTheme" parent="Theme.Keepass">
        <item name="android:navigationBarColor">?colorSurfaceVariant2</item>
    </style>

    <style name="Theme.Keepass" parent="Theme.Keepass.v27" />

    <style name="Theme.Keepass.v27" parent="Theme.Keepass.v23" />

    <style name="Theme.Keepass.v23" parent="Theme.Keepass.v21" />

    <style name="Theme.Keepass.v21" parent="Theme.Keepass.Base" />

    <style name="Theme.Keepass.Base" parent="Theme.Material3.DynamicColors.DayNight">
        <item name="android:windowBackground">@color/surface_color</item>
        <item name="android:colorBackground">@color/surface_color</item>
        <item name="colorSurface">@color/surface_color</item>
        <item name="colorSurfaceVariant">@color/surface_color_variant</item>
        <item name="colorSurfaceVariant2">@color/surface_color_variant2</item>

        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:fitsSystemWindows">false</item>

        <item name="android:imageButtonStyle">@style/Theme.Keepass.ImageButton</item>
        <item name="imageButtonStyle">@style/Theme.Keepass.ImageButton</item>

        <item name="android:checkboxStyle">@style/Theme.Keepass.CheckBox</item>

        <item name="android:textAppearance">@style/Theme.Keepass.Text</item>
        <item name="android:textAppearanceMedium">@style/Theme.Keepass.Text</item>

        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textColorPrimary">?attr/colorOnPrimary</item>
        <item name="android:editTextColor">?attr/colorOnSurface</item>

        <!-- Dialog -->
        <item name="android:alertDialogTheme">@style/Theme.Keepass.Dialog</item>
        <item name="alertDialogTheme">@style/Theme.Keepass.Dialog</item>
        <item name="dialogBackgroundColor">?colorSurfaceVariant2</item>

        <!-- CardView -->
        <item name="materialCardViewStyle">@style/Theme.Keepass.Cardview</item>
        <item name="cardViewStyle">@style/Theme.Keepass.Cardview</item>

        <!-- Toolbar -->
        <item name="collapsingToolbarLayoutStyle">@style/Theme.Keepass.CollapsingLayout</item>
        <item name="toolbarStyle">@style/Theme.Keepass.Toolbar</item>
        <item name="toolbarSpecialStyle">@style/Theme.Keepass.Toolbar.Special</item>
        <item name="toolbarActionStyle">@style/Theme.Keepass.Toolbar.Action</item>
        <item name="expandedTitleTextAppearance">@style/Theme.Keepass.Title.Large.OnSurface</item>
        <item name="collapsedTitleTextAppearance">@style/Theme.Keepass.Title.OnSurface</item>

        <!-- Tab -->
        <item name="tabStyle">@style/Theme.Keepass.TabLayout</item>

        <!-- Preference -->
        <item name="preferenceStyle">@style/Theme.Keepass.Preference.Style</item>
        <item name="dialogPreferenceStyle">@style/Theme.Keepass.Preference.Dialog.Style</item>
        <item name="preferenceCategoryStyle">@style/Theme.Keepass.Preference.Category.Style</item>

        <!-- Switch -->
        <item name="android:switchPreferenceStyle">@style/Theme.Keepass.SwitchPreference</item>
        <item name="switchPreferenceStyle">@style/Theme.Keepass.SwitchPreference</item>
        <item name="switchPreferenceCompatStyle">@style/Theme.Keepass.SwitchPreference</item>

        <!-- Edit Text -->
        <item name="textInputStyle">@style/Theme.Keepass.TextInputLayout</item>

        <!-- Snackbar -->
        <item name="snackbarStyle">@style/Theme.Keepass.SnackBar</item>
    </style>

    <!-- Toolbar Style -->
    <style name="Theme.Keepass.Toolbar.Base" parent="Widget.Material3.Toolbar" />

    <style name="Theme.Keepass.Toolbar.v21" parent="Theme.Keepass.Toolbar.Base" />

    <style name="Theme.Keepass.Toolbar" parent="Theme.Keepass.Toolbar.v21">
        <item name="elevation">0dp</item>
        <item name="background">@color/surface_color</item>
        <item name="android:background">@color/surface_color</item>
    </style>

    <style name="Theme.Keepass.CollapsingLayout" parent="Widget.Design.CollapsingToolbar">
        <item name="android:background">?attr/colorSurface</item>
        <item name="background">?attr/colorSurface</item>
        <item name="contentScrim">?attr/colorSurface</item>
    </style>

    <style name="Theme.Keepass.Toolbar.Transparent" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/transparent</item>
        <item name="background">@color/transparent</item>
    </style>
    <!-- Special Toolbar Style -->
    <style name="Theme.Keepass.Toolbar.Special" parent="Theme.Keepass.Toolbar">
        <item name="titleTextAppearance">@style/Theme.Keepass.Text</item>
        <item name="titleTextColor">?attr/colorOnSurface</item>
        <item name="subtitleTextAppearance">@style/Theme.Keepass.Text.Tiny</item>
        <item name="subtitleTextColor">?attr/colorSecondary</item>
        <item name="android:background">?attr/colorSurfaceContainer</item>
    </style>
    <!-- Action Style -->
    <style name="Theme.Keepass.Toolbar.Action" parent="Theme.Keepass.Toolbar" />

    <!-- Edit Text -->
    <style name="Theme.Keepass.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox" />

    <style name="Theme.Keepass.TextInputLayout.ExposedMenu" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu" />

    <!-- Tab -->
    <style name="Theme.Keepass.TabLayout" parent="@style/Widget.Material3.TabLayout" />

    <!-- Preference -->
    <style name="Theme.Keepass.Preference.Style" parent="@style/Preference.Material">
        <item name="android:layout">@layout/preference_material</item>
        <item name="allowDividerAbove">false</item>
        <item name="allowDividerBelow">false</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <style name="Theme.Keepass.Preference.Dialog.Style" parent="@style/Preference.DialogPreference.Material">
        <item name="allowDividerAbove">false</item>
        <item name="allowDividerBelow">false</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <style name="Theme.Keepass.Preference.Category.Style" parent="@style/Preference.Category.Material">
        <item name="android:layout">@layout/preference_category_material</item>
        <item name="allowDividerAbove">false</item>
        <item name="allowDividerBelow">false</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <!-- Switch -->
    <style name="Theme.Keepass.SwitchPreference" parent="@style/Preference.SwitchPreferenceCompat.Material">
        <item name="widgetLayout">@layout/preference_material_switch</item>
        <item name="allowDividerAbove">false</item>
        <item name="allowDividerBelow">false</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <!-- Chip -->
    <style name="Theme.Keepass.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">8dp</item>
        <item name="chipIconVisible">false</item>
        <item name="closeIconSize">24dp</item>
        <item name="ensureMinTouchTargetSize">false</item>
    </style>

    <style name="Theme.Keepass.Chip.Filter.Icon" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">8dp</item>
        <item name="chipIconVisible">true</item>
        <item name="closeIconVisible">true</item>
        <item name="closeIconSize">24dp</item>
        <item name="ensureMinTouchTargetSize">false</item>
    </style>

    <!-- Dialog -->
    <style name="Theme.Keepass.Dialog" parent="ThemeOverlay.Material3.Dialog.Alert">
        <item name="android:background">?attr/dialogBackgroundColor</item>
        <item name="background">?attr/dialogBackgroundColor</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
        <item name="dialogCornerRadius">@dimen/dialog_radius</item>
        <item name="buttonBarNegativeButtonStyle">@style/Theme.Keepass.Dialog.NegativeButtonStyle
        </item>
        <item name="buttonBarPositiveButtonStyle">@style/Theme.Keepass.Dialog.PositiveButtonStyle
        </item>
    </style>

    <style name="Theme.Keepass.Dialog.NegativeButtonStyle" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">?attr/colorPrimary</item>
    </style>

    <style name="Theme.Keepass.Dialog.PositiveButtonStyle" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">?attr/colorPrimary</item>
    </style>

    <!-- CardView -->
    <style name="Theme.Keepass.Cardview" parent="Widget.Material3.CardView.Filled">
        <item name="android:layout_marginTop">@dimen/card_view_margin_vertical</item>
        <item name="android:layout_marginBottom">@dimen/card_view_margin_vertical</item>
        <item name="android:layout_marginStart">@dimen/card_view_margin_horizontal</item>
        <item name="android:layout_marginEnd">@dimen/card_view_margin_horizontal</item>
        <item name="android:layout_marginLeft">@dimen/card_view_margin_horizontal</item>
        <item name="android:layout_marginRight">@dimen/card_view_margin_horizontal</item>
        <item name="cardBackgroundColor">?colorSurfaceVariant</item>
        <item name="android:padding">@dimen/card_view_padding</item>
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="Theme.Keepass.Cardview.Surface.Small" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">@dimen/small_card_radius</item>
        <item name="cardBackgroundColor">?colorSurfaceVariant</item>
    </style>

    <style name="Theme.Keepass.Cardview.Variant" parent="Theme.Keepass.Cardview">
        <item name="cardBackgroundColor">?attr/colorSurfaceVariant2</item>
    </style>

    <!-- CheckBox -->
    <style name="Theme.Keepass.CheckBox" parent="Widget.AppCompat.CompoundButton.CheckBox">
        <item name="android:textColor">?android:attr/textColor</item>
    </style>

    <!-- Text Style -->
    <style name="Theme.Keepass.Text" parent="android:style/TextAppearance">
        <item name="android:textColor">?android:attr/textColor</item>
    </style>

    <style name="Theme.Keepass.Title" parent="Theme.Keepass.Text">
        <item name="android:textSize">20sp</item>
    </style>

    <style name="Theme.Keepass.SubTitle" parent="Theme.Keepass.Text">
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Theme.Keepass.Text.Tiny" parent="Theme.Keepass.Text">
        <item name="android:textSize">12sp</item>
    </style>

    <style name="Theme.Keepass.Text.OnSurface" parent="android:style/TextAppearance">
        <item name="android:textColor">@color/on_surface_selector</item>
    </style>

    <style name="Theme.Keepass.Title.OnSurface" parent="Theme.Keepass.Text.OnSurface">
        <item name="android:textSize">20sp</item>
    </style>

    <style name="Theme.Keepass.Text.Large.OnSurface" parent="Theme.Keepass.Text.OnSurface">
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Theme.Keepass.Title.Large.OnSurface" parent="Theme.Keepass.Text.OnSurface">
        <item name="android:textSize">28sp</item>
    </style>

    <style name="Theme.Keepass.Text.Info.OnSurface" parent="Theme.Keepass.Text.OnSurface">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">italic</item>
    </style>

    <style name="Theme.Keepass.Text.Meta.OnSurface" parent="Theme.Keepass.Text.OnSurface">
        <item name="android:textSize">11sp</item>
    </style>

    <!-- Badge -->
    <style name="Theme.Keepass.Text.Badge" parent="Theme.Keepass.Text">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">?attr/colorOnSecondary</item>
        <item name="android:background">@drawable/background_rounded_square</item>
    </style>

    <!-- Nodes Text Style -->
    <style name="Theme.Keepass.Title.Entry" parent="Theme.Keepass.Text">
        <item name="android:textColor">@color/text_primary_color</item>
        <item name="android:tint">@color/text_primary_color</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Theme.Keepass.SubTitle.Entry" parent="Theme.Keepass.Text">
        <item name="android:textColor">@color/text_secondary_color</item>
        <item name="android:tint">@color/text_secondary_color</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="Theme.Keepass.Meta.Entry" parent="Theme.Keepass.Text.Tiny">
        <item name="android:textColor">@color/text_primary_color</item>
        <item name="android:tint">@color/text_primary_color</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="Theme.Keepass.Meta.Entry.Important" parent="Theme.Keepass.Meta.Entry">
        <item name="android:textStyle">italic|bold</item>
    </style>

    <style name="Theme.Keepass.Info.Entry" parent="Theme.Keepass.Text">
        <item name="android:textColor">@color/text_secondary_color</item>
        <item name="android:tint">@color/text_secondary_color</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Theme.Keepass.Icon.Entry" parent="Theme.Keepass.Text">
        <item name="tint">@color/text_secondary_color</item>
    </style>

    <style name="Theme.Keepass.Title.Group" parent="Theme.Keepass.Text">
        <item name="android:textColor">@color/text_primary_color</item>
        <item name="android:tint">@color/text_primary_color</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Theme.Keepass.Meta.Group" parent="Theme.Keepass.Text.Tiny">
        <item name="android:textColor">@color/text_primary_color</item>
        <item name="android:tint">@color/text_primary_color</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- Button Style -->
    <style name="Theme.Keepass.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:layout_margin">8dp</item>
    </style>

    <style name="Theme.Keepass.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_margin">8dp</item>
    </style>

    <style name="Theme.Keepass.Base.ImageButton" parent="Widget.AppCompat.ImageButton" />

    <style name="Theme.Keepass.v21.ImageButton" parent="Theme.Keepass.Base.ImageButton">
        <item name="android:gravity">center</item>
    </style>

    <style name="Theme.Keepass.ImageButton" parent="Theme.Keepass.v21.ImageButton">
        <item name="android:colorForeground">?attr/colorOnSecondary</item>
        <item name="android:background">@drawable/background_image_button</item>
        <item name="backgroundTint">?attr/colorSecondary</item>
    </style>

    <style name="Theme.Keepass.ImageButton.Simple" parent="Theme.Keepass.v21.ImageButton">
        <item name="android:colorForeground">@color/secondary_selector</item>
        <item name="tint">@color/secondary_selector</item>
        <item name="android:background">?android:attr/actionBarItemBackground</item>
        <item name="backgroundTint">@null</item>
        <item name="android:padding">12dp</item>
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
    </style>

    <style name="Theme.Keepass.ImageButton.OnSurface" parent="Theme.Keepass.ImageButton.Simple">
        <item name="android:colorForeground">?attr/colorOnSurface</item>
        <item name="tint">?attr/colorOnSurface</item>
    </style>

    <!-- Item Style -->
    <style name="Theme.Keepass.Selectable.Item" parent="Theme.Keepass">
        <item name="android:background">@drawable/background_item_selection</item>
        <item name="background">@drawable/background_item_selection</item>
    </style>

    <!-- Icon Style -->
    <style name="Theme.Keepass.Icon" parent="Theme.Keepass.v21.ImageButton">
        <item name="android:background">@drawable/background_icon</item>
        <item name="backgroundTint">?android:attr/windowBackground</item>
    </style>

    <!-- FAB -->
    <style name="Theme.Keepass.Fab" parent="Widget.Material3.FloatingActionButton.Primary" />

    <style name="Theme.Keepass.Fab.Special" parent="Widget.Material3.FloatingActionButton.Secondary">
        <item name="fabCustomSize">@dimen/button_small_size</item>
    </style>

    <!-- Menu FAB -->
    <style name="Theme.Keepass.Fab.Menu" parent="Widget.Material3.ExtendedFloatingActionButton.Icon.Primary">
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <!-- Form -->
    <style name="Theme.Keepass.TextAppearance.LabelTextStyle" parent="Theme.Keepass.Text">
        <item name="android:textColor">?attr/colorSecondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:paddingLeft">8dp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingRight">8dp</item>
        <item name="android:paddingEnd">8dp</item>
    </style>

    <style name="Theme.Keepass.TextAppearance.LabelTableTextStyle" parent="Theme.Keepass.Text">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Theme.Keepass.TextAppearance.TextNode" parent="Theme.Keepass.Text">
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:paddingLeft">8dp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingRight">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Snackbar -->
    <style name="Theme.Keepass.SnackBar" parent="Widget.Material3.Snackbar">
        <item name="backgroundTint">@color/red</item>
    </style>

    <!-- Transparent -->
    <style name="Theme.Transparent" parent="Theme.Material3.DynamicColors.Dark">
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <!-- Keyboard -->
    <style name="Theme.Keepass.Keyboard" parent="Theme.AppCompat">
        <item name="android:paddingTop">4dp</item>
        <item name="background">@color/grey_blue_deep</item>
        <item name="keyBackground">@drawable/key_background</item>
        <item name="keyTextSize">22sp</item>
        <item name="keyTextColor">@color/white</item>
        <item name="labelTextSize">14sp</item>
        <item name="verticalCorrection">-10dip</item>
        <item name="popupLayout">@layout/keyboard_popup_fields</item>
    </style>
</resources>
